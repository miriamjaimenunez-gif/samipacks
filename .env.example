# Copia este archivo como ".env" y llena los valores.
# En tu PC (XAMPP): DB_HOST=127.0.0.1, DB_USER=root, DB_PASSWORD=(vacío), DB_SSL=false
# En Render (Aiven): usa los datos que copiaste del panel de Aiven, y DB_SSL=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=samipacks_app_db
DB_SSL=false
